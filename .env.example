# ─────────────────────────────────────────────────────────────
# Exemple de configuration CLEAN
# Copiez ce fichier en .env et renseignez vos vraies valeurs.
# Le fichier .env lui-même est ignoré par Git (voir .gitignore).
# ─────────────────────────────────────────────────────────────

# Sécurité
SECRET_KEY=change-me-to-a-long-random-string
DEBUG=True
ALLOWED_HOSTS=*

# Cloud sync
SITE_ID=SITE_PARIS_01
CLOUD_SYNC_URL=https://clean-cloud-api.herokuapp.com/api/sync/
CLOUD_API_KEY=your-secret-key-here

# Base de données cloud (MySQL)
CLOUD_DB_NAME=dhavant_db
CLOUD_DB_USER=dhavant
CLOUD_DB_PASSWORD=change-me
CLOUD_DB_HOST=mysql-dhavant.alwaysdata.net
CLOUD_DB_PORT=3306

# OpenPay (paiements)
OPENPAY_API_KEY=change-me
OPENPAY_URL=https://api.openpay-cg.com/v1/payment-link

# CSRF (origines de confiance pour le mode partagé)
CSRF_TRUSTED_ORIGINS=https://omerpay.share.zrok.io

# Mode de synchronisation : LOCAL, CLOUD ou AUTO
LIVE_MODE=AUTO
